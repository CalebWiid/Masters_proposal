  shorttitle = {{{ModDrop}}},
  author = {Neverova, Natalia and Wolf, Christian and Taylor, Graham and Nebout, Florian},
  year = 2016,
  month = aug,
  journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
  volume = {38},
